generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CustomerStatus {
  lead
  invited
  active
}

enum ServiceBillingType {
  one_time
  subscription
}

enum BillingInterval {
  monthly
  semiannual
  annual
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

enum InviteStatus {
  pending
  completed
  expired
}

enum TicketStatus {
  open
  in_progress
  closed
}

enum DebtSourceType {
  job
  subscription
}

enum DebtItemType {
  one_time
  subscription
}

enum DebtStatus {
  open
  cancelled
}

model Customer {
  id            String   @id @default(uuid())
  company       String?
  website       String?
  vat           String?
  billingAddress String?
  pec           String?
  sdi           String?

  firstName     String?
  lastName      String?
  email         String?
  phone         String?

  status        CustomerStatus @default(lead)

  wpUserId      String?
  wpUsername    String?

  crmCompanyId        String?
  crmPrimaryContactId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobs          Job[]
  subscriptions Subscription[]
  invites       Invite[]
  tickets       Ticket[]
  debtItems     DebtItem[]
  payments      PaymentEntry[]
  contacts      CustomerContact[]
  notes         CustomerNote[]

  @@index([status])
  @@index([wpUserId])
  @@index([crmCompanyId])
  @@index([email])
}

model CustomerContact {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name       String?
  email      String?
  phone      String?
  role       String?
  isPrimary  Boolean  @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
  @@index([email])
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  text       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId, createdAt])
}

model Service {
  id            String   @id @default(uuid())
  name          String
  description   String?
  price         Decimal  @db.Decimal(12, 2)
  billingType   ServiceBillingType
  billingInterval BillingInterval?
  active        Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  priceHistory  ServicePriceHistory[]
  jobLinks      JobService[]
  subscriptions Subscription[]

  @@index([active])
  @@index([billingType])
}

model ServicePriceHistory {
  id         String   @id @default(uuid())
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  oldPrice   Decimal  @db.Decimal(12, 2)
  newPrice   Decimal  @db.Decimal(12, 2)
  note       String?

  changedAt  DateTime @default(now())

  @@index([serviceId, changedAt])
}

model Job {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title       String
  description String?
  status      String?   // mantiene flessibilità come in MVP (es. "open", "done", ecc.)
  amount      Decimal?  @db.Decimal(12, 2)

  startDate   DateTime?
  dueDate     DateTime?

  crmDealId     String?
  crmCompanyId  String?
  crmContactId  String?
  pipelineName  String?

  documentsText String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  services     JobService[]
  notes        JobNote[]
  subscriptions Subscription[]
  @@index([customerId])
  @@index([status])
  @@index([crmDealId])
}

model JobService {
  jobId     String
  serviceId String

  job       Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@id([jobId, serviceId])
  @@index([serviceId])
}

model JobNote {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId, createdAt])
}

model Subscription {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  jobId         String?
  job           Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  purchaseDate  DateTime?
  renewalDate   DateTime?

  billingType     ServiceBillingType
  billingInterval BillingInterval?

  priceAtSale   Decimal  @db.Decimal(12, 2)
  status        SubscriptionStatus @default(active)

  lastReminderSent DateTime?

  crmDealId     String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId, status])
  @@index([jobId])
  @@index([serviceId])
  @@index([renewalDate])
}

model Invite {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  token       String   @unique
  status      InviteStatus @default(pending)

  expiresAt   DateTime?
  completedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId, status])
}

model Ticket {
  id         String   @id @default(uuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  wpUserId   String?
  email      String?
  subject    String
  message    String
  status     TicketStatus @default(open)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([wpUserId])
}

model DebtItem {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  sourceType DebtSourceType
  sourceId   String

  itemType   DebtItemType
  label      String?
  dueDate    DateTime?

  amountTotal Decimal @db.Decimal(12, 2)
  amountPaid  Decimal @db.Decimal(12, 2) @default(0)

  status     DebtStatus @default(open)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  payments   PaymentEntry[]

  @@unique([sourceType, sourceId])
  @@index([customerId, status])
  @@index([dueDate])
}

model PaymentEntry {
  id         String   @id @default(uuid())
  debtItemId String
  debtItem   DebtItem @relation(fields: [debtItemId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  date       DateTime @default(now())
  amount     Decimal  @db.Decimal(12, 2)
  note       String?

  createdAt  DateTime @default(now())

  @@index([debtItemId, date])
  @@index([customerId, date])
}
